# -----------------------------------------------------------------------
# LLM Provider — choose "groq" or "mistral"
# -----------------------------------------------------------------------
LLM_PROVIDER=groq

# -----------------------------------------------------------------------
# API Keys — fill in the one matching your chosen LLM_PROVIDER
# -----------------------------------------------------------------------

# Groq (fast, free tier available) — get key at https://console.groq.com
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# Mistral — get key at https://console.mistral.ai
MISTRAL_API_KEY=YOUR_KEY_HERE

# -----------------------------------------------------------------------
# Model override (optional — defaults shown below are auto-selected)
#   Groq default  : llama-3.3-70b-versatile
#   Mistral default: mistral-small-latest
# -----------------------------------------------------------------------
# LLM_MODEL=llama-3.3-70b-versatile
